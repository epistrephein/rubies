<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title><%= @title || 'Rubies' %></title>
    <meta name="description" content="An API interface to Ruby versions, releases and branches.">
    <meta name="author" content="Tommaso Barbato">

    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/img/safari-pinned-tab.svg" color="#c23b2a">
    <meta name="msapplication-TileColor" content="#0b090a">
    <meta name="theme-color" content="#0b090a">

    <meta property="og:title" content="Rubies">
    <meta property="og:description" content="An API interface to Ruby versions, releases and branches.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://rubies.io">
    <meta property="og:image" content="https://rubies.io/img/rubies-og.png">
    <meta property="og:locale" content="en_US">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Rubies">
    <meta name="twitter:description" content="An API interface to Ruby versions, releases and branches.">
    <meta name="twitter:url" content="https://rubies.io/">
    <meta name="twitter:image" content="https://rubies.io/img/rubies-og.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="/css/rubies.css">
    <script>
      (function() {
        var stored = null;
        try { stored = localStorage.getItem('rubies-theme'); } catch(e) {}
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', stored || (prefersDark ? 'dark' : 'light'));
        try {
          if (performance.navigation.type === 2) {
            document.documentElement.classList.add('no-animate');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
      <svg class="icon-moon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M12.5 9a6 6 0 0 1-7.5-7.5A5.5 5.5 0 1 0 12.5 9z" fill="currentColor"/>
      </svg>
      <svg class="icon-sun" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="2.5" fill="currentColor"/>
        <line x1="7" y1="0.5" x2="7" y2="2.5"   stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="7" y1="11.5" x2="7" y2="13.5"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="0.5" y1="7" x2="2.5" y2="7"    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="11.5" y1="7" x2="13.5" y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2.55" y1="2.55" x2="3.96" y2="3.96" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="10.04" y1="10.04" x2="11.45" y2="11.45" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="11.45" y1="2.55" x2="10.04" y2="3.96" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="3.96" y1="10.04" x2="2.55" y2="11.45" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <header class="site-header" role="banner">
      <a href="/" class="gem-icon" aria-label="Rubies home">
        <svg width="44" height="40" viewBox="0 0 44 40" fill="none" aria-hidden="true">
          <path d="M10 2 L34 2 L42 14 L22 38 L2 14 Z" fill="#6b1c12" stroke="#c23b2a" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M10 2 L22 12 L2 14 Z" fill="#8b2318"/>
          <path d="M10 2 L34 2 L22 12 Z" fill="#c23b2a"/>
          <path d="M34 2 L42 14 L22 12 Z" fill="#8b2318"/>
          <path d="M2 14 L22 12 L22 38 Z" fill="#5a1810"/>
          <path d="M42 14 L22 38 L22 12 Z" fill="#4e1410"/>
        </svg>
      </a>
      <h1 class="site-title"><a href="/">RUBIES<span class="tld">.IO</span></a></h1>
      <p class="site-tagline">API interface to Ruby versions</p>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="footer-links">
        <a href="https://github.com/epistrephein/rubies">github</a>
        <span class="footer-sep" aria-hidden="true"></span>
        <a href="https://status.rubies.io">status</a>
      </div>
      <p>No cookies. No tracking.</p>
    </footer>
    <script>
      window.addEventListener('pageshow', function(e) {
        if (e.persisted) document.documentElement.classList.add('no-animate');
      });
      var toggle = document.getElementById('theme-toggle');
      toggle.setAttribute('aria-pressed', document.documentElement.getAttribute('data-theme') === 'dark' ? 'true' : 'false');
      toggle.addEventListener('click', function() {
        var html = document.documentElement;
        var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.classList.add('is-switching');
        html.setAttribute('data-theme', next);
        toggle.setAttribute('aria-pressed', next === 'dark' ? 'true' : 'false');
        try { localStorage.setItem('rubies-theme', next); } catch(e) {}
        setTimeout(function() { html.classList.remove('is-switching'); }, 300);
      });
    </script>
  </body>
</html>
