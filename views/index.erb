<section class="branches-section">
  <div class="section-label">Active branches</div>

  <div class="branches-grid">
    <div class="branch-card">
      <div class="branch-card-status">
        <span class="pulse-dot normal" aria-hidden="true"></span>
        Normal maintenance
      </div>
      <div class="branch-versions">
        <% @normal.each do |version| %>
          <span class="vtag"><%= version %></span>
        <% end %>
        <% if @normal.empty? %>
          <span class="vtag-none">—</span>
        <% end %>
      </div>
    </div>

    <div class="branch-card">
      <div class="branch-card-status">
        <span class="pulse-dot security" aria-hidden="true"></span>
        Security only
      </div>
      <div class="branch-versions">
        <% @security.each do |version| %>
          <span class="vtag"><%= version %></span>
        <% end %>
        <% if @security.empty? %>
          <span class="vtag-none">—</span>
        <% end %>
      </div>
    </div>
  </div>

  <p class="last-update">Last update: <%= @last_update %></p>
</section>

<section class="api-section">
  <div class="section-label">API reference</div>

  <div class="api-block">
    <div class="api-header-row">
      <span class="api-method-badge">GET</span>
      <span class="api-base-url"><strong>https://rubies.io</strong>/api/<em>:key</em></span>
    </div>

    <div class="api-group">
      <p class="api-group-name">Statuses</p>
      <div class="api-routes">
        <% @statuses_ex.each do |status| %>
          <a class="api-route" href="/api/<%= status %>">/<%= status %></a>
        <% end %>
      </div>
    </div>

    <div class="api-group">
      <p class="api-group-name">Branches</p>
      <div class="api-routes">
        <% @branches_ex.each do |branch| %>
          <a class="api-route" href="/api/<%= branch %>">/<%= branch %></a>
        <% end %>
        <span class="api-route-etc">…and more</span>
      </div>
    </div>

    <div class="api-group">
      <p class="api-group-name">Releases</p>
      <div class="api-routes">
        <% @releases_ex.each do |release| %>
          <a class="api-route" href="/api/<%= release %>">/<%= release %></a>
        <% end %>
        <span class="api-route-etc">…and more</span>
      </div>
    </div>
  </div>
</section>
